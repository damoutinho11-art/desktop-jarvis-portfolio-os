{
  "description": "Evidence freshness and refresh policy. Read-only by default; auto-refresh creates unverified public drafts only.",
  "target_asset_ids": ["vwce_global_core_candidate"],
  "public_source_fetch_path": "jarvis/data/public_source_fetch.example.json",
  "rules": [
    {
      "evidence_type": "fund_metadata",
      "max_age_days": 90,
      "refresh_mode": "public_auto_refresh_allowed",
      "source_types_allowed": ["provider_product_page", "provider_factsheet_pdf", "provider_kiid_pdf"],
      "notes": "Core fund metadata can be refreshed from public provider sources."
    },
    {
      "evidence_type": "fee_metadata",
      "max_age_days": 90,
      "refresh_mode": "public_auto_refresh_allowed",
      "source_types_allowed": ["provider_product_page", "provider_factsheet_pdf", "provider_kiid_pdf"],
      "notes": "Fee metadata can be refreshed from public provider sources."
    },
    {
      "evidence_type": "distribution_policy",
      "max_age_days": 90,
      "refresh_mode": "public_auto_refresh_allowed",
      "source_types_allowed": ["provider_product_page", "provider_factsheet_pdf", "provider_kiid_pdf"],
      "notes": "Distribution policy can be refreshed from public provider sources."
    },
    {
      "evidence_type": "market_data",
      "max_age_days": 7,
      "refresh_mode": "public_auto_refresh_allowed",
      "source_types_allowed": ["public_market_data_page", "public_crypto_market_api", "public_fx_api"],
      "notes": "Market data freshness window is short."
    },
    {
      "evidence_type": "exposure_data",
      "max_age_days": 90,
      "refresh_mode": "public_auto_refresh_allowed",
      "source_types_allowed": ["provider_factsheet_pdf", "provider_product_page"],
      "notes": "Exposure data can be refreshed from public provider holdings/exposure sources."
    },
    {
      "evidence_type": "tax_route",
      "max_age_days": 180,
      "refresh_mode": "manual_refresh_required",
      "source_types_allowed": ["manual_url_reference"],
      "notes": "Tax route evidence requires manual review."
    },
    {
      "evidence_type": "platform_availability",
      "max_age_days": 90,
      "refresh_mode": "account_specific_manual_required",
      "source_types_allowed": ["public_platform_page"],
      "notes": "Platform availability for real account execution must be confirmed manually in-account."
    },
    {
      "evidence_type": "custody_route",
      "max_age_days": 90,
      "refresh_mode": "account_specific_manual_required",
      "source_types_allowed": ["public_platform_page"],
      "notes": "Custody route is account-specific."
    },
    {
      "evidence_type": "crypto_risk_notes",
      "max_age_days": 90,
      "refresh_mode": "manual_refresh_required",
      "source_types_allowed": ["manual_url_reference"],
      "notes": "Crypto risk notes require manual review."
    }
  ],
  "read_only_by_default": true,
  "verified_by_user_by_default": false,
  "approvals_created": false,
  "registry_mutation_allowed": false,
  "buy_sell_requests_created": false,
  "trades_executed": false
}
